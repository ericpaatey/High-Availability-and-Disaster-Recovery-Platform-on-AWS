{
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 0,
  "panels": [
    {
      "title": "CPU Usage",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Memory Usage",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(container_memory_usage_bytes)",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Pod Restarts",
      "type": "timeseries",
      "targets": [
        {
          "expr": "increase(kube_pod_container_status_restarts_total[5m])",
          "refId": "C"
        }
      ]
    },
    {
      "title": "Node Availability",
      "type": "stat",
      "targets": [
        {
          "expr": "up{kubernetes_io_hostname!=\"\"}",
          "refId": "D"
        }
      ]
    },
    {
      "title": "Network Latency",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(container_network_receive_bytes_total[5m])",
          "refId": "E"
        }
      ]
    }
  ],
  "schemaVersion": 38,
  "style": "dark",
  "tags": [
    "kubernetes",
    "eks",
    "ha",
    "dr",
    "chaos-engineering"
  ],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timezone": "browser",
  "title": "HA + DR EKS Platform Dashboard",
  "version": 1
}